import java.util.Scanner;

public class PriorityScheduling {

    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        System.out.print("Enter Number of Processes: ");
        int n = sc.nextInt();

        int[] process = new int[n];
        int[] arrivalTime = new int[n];
        int[] burstTime = new int[n];
        int[] priority = new int[n];
        int[] completionTime = new int[n];
        int[] waitingTime = new int[n];
        int[] tat = new int[n];
        int[] burstCopy = new int[n];

        // Input
        for (int i = 0; i < n; i++) {

            process[i] = i + 1;

            System.out.print("\nEnter Arrival Time for P" + (i + 1) + ": ");
            arrivalTime[i] = sc.nextInt();

            System.out.print("Enter Burst Time for P" + (i + 1) + ": ");
            burstTime[i] = sc.nextInt();

            System.out.print("Enter Priority for P" + (i + 1) + ": ");
            priority[i] = sc.nextInt();

            burstCopy[i] = burstTime[i];
        }

        int completed = 0;
        int currentTime = 0;

        while (completed < n) {

            int highestPriority = -1;

            for (int i = 0; i < n; i++) {

                if (arrivalTime[i] <= currentTime &&
                        burstTime[i] > 0) {

                    if (highestPriority == -1 ||
                            priority[i] < priority[highestPriority]) {

                        highestPriority = i;
                    }
                }
            }

            // No process available
            if (highestPriority == -1) {

                currentTime++;
            }

            else {

                burstTime[highestPriority]--;

                currentTime++;

                // Process completed
                if (burstTime[highestPriority] == 0) {

                    completed++;

                    completionTime[highestPriority] = currentTime;

                    tat[highestPriority] =
                            completionTime[highestPriority]
                                    - arrivalTime[highestPriority];

                    waitingTime[highestPriority] =
                            tat[highestPriority]
                                    - burstCopy[highestPriority];
                }
            }
        }

        double avgWT = 0;
        double avgTAT = 0;

        System.out.println("\nProcess\tAT\tBT\tPriority\tCT\tTAT\tWT");

        for (int i = 0; i < n; i++) {

            avgWT += waitingTime[i];
            avgTAT += tat[i];

            System.out.println(
                    "P" + process[i] + "\t"
                            + arrivalTime[i] + "\t"
                            + burstCopy[i] + "\t"
                            + priority[i] + "\t\t"
                            + completionTime[i] + "\t"
                            + tat[i] + "\t"
                            + waitingTime[i]);
        }

        System.out.println("\nAverage Waiting Time: " + (avgWT / n));

        System.out.println("Average Turnaround Time: " + (avgTAT / n));

        sc.close();
    }
}
